{
  "name": "site-2",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "astro": "astro",
    "astrocheck": "astro check",
    "agent:markdown": "node scripts/agent-markdown.mjs",
    "agent:skills": "node scripts/generate-agent-skills-index.mjs",
    "build": "npm run feeds:pull:stale-ok && npm run events:pull:stale-ok && npm run agent:markdown && npm run agent:skills && astro build",
    "check": "npm run lint; npm run tsc; npm run knip; npm run test; npm run astrocheck; npm run images:check",
    "dev": "astro dev",
    "feeds:notify": "node scripts/community-feed-notifier.mjs",
    "feeds:notify:dry-run": "node scripts/community-feed-notifier.mjs --dry-run",
    "feeds:pull": "node scripts/fetch-feeds.mjs",
    "feeds:pull:stale-ok": "node scripts/fetch-feeds.mjs --stale-ok",
    "events:pull": "tsx scripts/fetch-meetup-events.mjs",
    "events:pull:stale-ok": "tsx scripts/fetch-meetup-events.mjs --stale-ok",
    "images:optimize": "node scripts/optimize-images.mjs",
    "images:check": "node scripts/optimize-images.mjs --check",
    "knip": "knip",
    "lint": "eslint . --ext .js,.mjs,.ts,.tsx,.astro --no-warn-ignored",
    "preview": "astro preview",
    "reminder": "tsx scripts/meetup-event-reminder.mjs",
    "reminder:dry-run": "tsx scripts/meetup-event-reminder.mjs --dry-run",
    "test": "vitest run",
    "tsc": "tsc --noEmit"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/mdx": "^7.0.2",
    "@astrojs/react": "^6.0.1",
    "@astrojs/sitemap": "^3.7.3",
    "@tailwindcss/vite": "^4.1.17",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "astro": "^7.0.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-icons": "^5.5.0",
    "rss-parser": "^3.13.0",
    "tailwindcss": "^4.1.17"
  },
  "overrides": {
    "@astrojs/check": {
      "@astrojs/language-server": "2.16.11"
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@typescript-eslint/parser": "^8.46.4",
    "eslint": "^9.39.1",
    "eslint-plugin-astro": "^1.5.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "knip": "^5.70.1",
    "sharp": "^0.34.5",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
