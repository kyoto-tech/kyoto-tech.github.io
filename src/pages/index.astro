---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import WhyJoin from "../components/WhyJoin.astro";
import Calendar from "../components/Calendar.astro";
import Footer from "../components/Footer.astro";
import { FaGithub, FaDiscord, FaMeetup, FaEnvelope } from "react-icons/fa";
import { FaExternalLinkAlt } from "react-icons/fa";
import FeedTimestamps from "../components/FeedTimestamps.jsx";
import { useTranslations } from "../i18n/utils";
import memberFeeds from "../data/member-feeds.json";
import compositeFeed from "../data/composite-feed.json";
import eventLocations from "../data/event-locations.json";
import meetupEventData from "../data/meetup-events.json";
import {
  isMeetupEvent,
  selectNextMeetupEvent,
  selectUpcomingMeetupEvents,
} from "../lib/meetup-events";

const { lang = "en" } = Astro.props;
const t = useTranslations(lang);

const meetupUrl =
  lang === "ja"
    ? "https://www.meetup.com/ja-JP/kyoto-tech-meetup/"
    : "https://www.meetup.com/kyoto-tech-meetup/";
const discordUrl = "https://discord.gg/mXFWEHDKeu";
const githubUrl = "https://github.com/kyoto-tech";
const contactUrl = "https://forms.gle/NPtc1G1vM9jGBYhp6";

const quickLinks = [
  {
    href: meetupUrl,
    icon: FaMeetup,
    titleKey: "home.quickLinks.meetup.title",
    descriptionKey: "home.quickLinks.meetup.description",
  },
  {
    href: discordUrl,
    icon: FaDiscord,
    titleKey: "home.quickLinks.discord.title",
    descriptionKey: "home.quickLinks.discord.description",
  },
  {
    href: githubUrl,
    icon: FaGithub,
    titleKey: "home.quickLinks.github.title",
    descriptionKey: "home.quickLinks.github.description",
  },
  {
    href: contactUrl,
    icon: FaEnvelope,
    titleKey: "home.quickLinks.contact.title",
    descriptionKey: "home.quickLinks.contact.description",
  },
] as const;

const calendarLegendItems = [
  {
    titleKey: "home.calendar.legend.coffee.title",
    descriptionKey: "home.calendar.legend.coffee.description",
    image: "/images/kyoto-tech-morning-tech-&-coffee.jpg",
    color: "var(--accent)",
    imageClass: "object-[center_65%]",
  },
  {
    titleKey: "home.calendar.legend.hackDay.title",
    descriptionKey: "home.calendar.legend.hackDay.description",
    image: "/images/kyoto-tech-meetup-hack-day.jpg",
    color: "#0f766e",
    imageClass: "object-center",
  },
  {
    titleKey: "home.calendar.legend.special.title",
    descriptionKey: "home.calendar.legend.special.description",
    image: "/images/kyoto-tech-meetup-hack-day_2.jpg",
    color: "#7c3aed",
    imageClass: "object-center",
  },
] as const;

type MemberFeed = {
  name: string;
  siteUrl: string;
  feedUrl: string;
};

type CompositeItem = {
  id: string;
  title: string;
  link: string;
  publishedAt: string;
  summary?: string;
  image?: string | null;
  source: MemberFeed;
};

type CompositeFeed = MemberFeed & {
  items: CompositeItem[];
  error?: string;
};

const benefits = [
  {
    title: t("home.benefit1.title"),
    description: t("home.benefit1.description"),
  },
  {
    title: t("home.benefit2.title"),
    description: t("home.benefit2.description"),
  },
  {
    title: t("home.benefit3.title"),
    description: t("home.benefit3.description"),
  },
];

const locale = lang === "ja" ? "ja-JP" : "en-US";
const cachedMeetupEvents = Array.isArray(meetupEventData?.events)
  ? (meetupEventData.events as unknown[]).filter(isMeetupEvent)
  : [];
const buildNow = new Date();
const events = selectUpcomingMeetupEvents(cachedMeetupEvents, { now: buildNow });
const nextEvent = selectNextMeetupEvent(events, { now: buildNow });
const nextEventUrl = nextEvent?.link ?? meetupUrl;

const memberFeedList = (memberFeeds as MemberFeed[]) ?? [];
const compositeFeedEntries = Array.isArray(compositeFeed?.feeds)
  ? (compositeFeed.feeds as CompositeFeed[])
  : [];
const feedsWithItems = memberFeedList.map((feed) => {
  const match =
    compositeFeedEntries.find(
      (entry) =>
        entry.feedUrl === feed.feedUrl ||
        entry.siteUrl === feed.siteUrl ||
        entry.name === feed.name,
    ) ?? null;
  return {
    ...feed,
    items: match?.items ?? [],
    error: match?.error,
  };
});

const formatDate = (value: string) => {
  const date = new Date(value);
  if (Number.isNaN(date.valueOf())) return null;
  return date.toLocaleDateString(locale, {
    timeZone: "Asia/Tokyo",
    month: "short",
    day: "numeric",
    year: "numeric",
  });
};
---

<Layout>
  <Header
    hasNextEvent={Boolean(nextEvent)}
    lang={lang}
    nextEventUrl={nextEventUrl}
  />

  <div class="mx-auto max-w-6xl pt-20">
    <Hero
      event={nextEvent}
      fallbackCtaLabel={t("home.hero.fallbackCta")}
      fallbackUrl={meetupUrl}
      imageAlt={t("home.hero.imageAlt")}
      imageSrc="/images/kyoto-tech-community-presentation.jpeg"
      lang={lang}
      now={buildNow}
      primaryCtaLabel={t("home.hero.primaryCta")}
      reassurance={t("home.hero.reassurance")}
      secondaryCtaLabel={t("home.hero.secondaryCta")}
      title={t("home.header.title")}
      subtitle={t("home.header.subtitle")}
    />
  </div>

  <main id="main-content" class="space-y-0">
    <section id="calendar" class="scroll-mt-24 bg-white px-6 py-16 md:px-12">
      <div class="mx-auto max-w-5xl">
        <h2 class="text-3xl font-semibold text-slate-900">
          {t("home.calendar.title")}
        </h2>

        <FeedTimestamps
          client:load
          generatedAt={compositeFeed?.generatedAt}
          intervalHours={3}
          updatedLabel={t("home.communityFeed.updated")}
          nextLabel={t("home.communityFeed.nextUpdate")}
        />

        <Calendar events={events} lang={lang} />

        <div class="mt-5 grid gap-4 text-sm text-slate-700 md:grid-cols-3">
          {
            calendarLegendItems.map((item) => (
              <article class="overflow-hidden rounded-xl border border-slate-200 bg-white">
                <div class="h-32 overflow-hidden bg-slate-100">
                  <img
                    src={item.image}
                    alt=""
                    loading="lazy"
                    decoding="async"
                    class={`h-full w-full object-cover ${item.imageClass}`}
                  />
                </div>
                <div class="p-4">
                  <div class="flex items-center gap-2">
                    <span
                      class="h-3 w-3 shrink-0 rounded-full"
                      style={`background-color: ${item.color};`}
                      aria-hidden="true"
                    />
                    <h3 class="font-semibold text-slate-900">
                      {t(item.titleKey)}
                    </h3>
                  </div>
                  <p class="mt-2">{t(item.descriptionKey)}</p>
                </div>
              </article>
            ))
          }
        </div>

        <div id="locations" class="mt-12 scroll-mt-24">
          <h3 class="text-2xl font-semibold text-slate-900">
            {t("home.locations.title")}
          </h3>
          <p class="mt-2 text-base text-slate-600">
            {t("home.locations.note")}
          </p>
          <div class="mt-6 grid gap-5 md:grid-cols-2">
            {eventLocations.map((location) => (
              <article class="overflow-hidden rounded-2xl border border-slate-200/80 bg-white">
                <div class="p-4">
                  <h4 class="text-lg font-semibold text-slate-900">
                    {location.name}
                  </h4>
                </div>
                <div class="h-72 bg-slate-100">
                  <iframe
                    src={location.embedUrl}
                    title={t("a11y.mapTitle").replace("{name}", location.name)}
                    aria-label={t("a11y.mapLabel").replace("{name}", location.name)}
                    width="100%"
                    height="100%"
                    style="border:0; display: block;"
                    allowfullscreen=""
                    loading="lazy"
                    referrerpolicy="no-referrer-when-downgrade"
                  >
                  </iframe>
                </div>
              </article>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section id="community-hub" class="scroll-mt-24 bg-white/90 px-6 py-12 md:px-12">
      <div class="mx-auto max-w-5xl">
        <h2 class="text-3xl font-semibold text-slate-900">
          {t("home.quickLinks.title")}
        </h2>
        <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          {
            quickLinks.map((link) => (
              <a
                class="group flex h-full items-start gap-3 rounded-2xl border border-slate-200/80 bg-white/95 p-4 shadow-lg shadow-stone-900/5 transition hover:-translate-y-0.5 hover:border-(--accent) hover:bg-white"
                href={link.href}
                target="_blank"
                rel="noreferrer"
              >
                <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-(--accent)/10 text-(--accent)">
                  <link.icon size={18} aria-hidden="true" />
                </span>
                <span class="flex flex-col">
                  <span class="text-base font-semibold text-slate-900 group-hover:text-(--accent)">
                    {t(link.titleKey)}
                  </span>
                  <span class="mt-1 text-sm text-slate-600">
                    {t(link.descriptionKey)}
                  </span>
                </span>
                <FaExternalLinkAlt
                  className="ml-auto self-center shrink-0 text-xs text-slate-400 transition group-hover:text-(--accent)"
                  aria-hidden="true"
                />
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <section id="community-feed" class="bg-white px-6 py-16 md:px-12">
      <div class="mx-auto max-w-5xl space-y-8">
        <div
          class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between"
        >
          <div>
            <h2 class="text-3xl font-semibold text-slate-900">
              {t("home.communityFeed.title")}
            </h2>
            <p class="mt-3 text-slate-600">
              {t("home.communityFeed.description")}
            </p>
            {
              compositeFeed?.generatedAt ? (
                <FeedTimestamps
                  client:load
                  generatedAt={compositeFeed.generatedAt}
                  intervalHours={3}
                  updatedLabel={t("home.communityFeed.updated")}
                  nextLabel={t("home.communityFeed.nextUpdate")}
                />
              ) : null
            }
          </div>
        </div>

        <div class="flex flex-col gap-5">
          <div class="space-y-5">
            {
              feedsWithItems.map((feed) => (
                <article
                  class="flex h-full flex-col overflow-visible rounded-2xl border border-slate-200/70 bg-white/95 p-5 shadow-lg shadow-stone-900/5 ring-1 ring-white/80"
                >
                  <div class="flex flex-wrap items-center gap-3">
                    <h4 class="text-lg font-semibold text-slate-900">
                      {feed.name}
                    </h4>
                    <div class="ml-auto flex items-center gap-2">
                      {feed.error ? (
                        <span class="rounded-full bg-amber-100 px-3 py-1 text-xs font-semibold text-amber-800">
                          {t("home.communityFeed.fetchError")}
                        </span>
                      ) : null}
                      {feed.siteUrl ? (
                        <a
                          class="inline-flex items-center rounded-full border border-(--accent) bg-(--accent)/10 px-3 py-1 text-xs font-semibold text-(--accent)"
                          href={feed.siteUrl}
                          target="_blank"
                          rel="noreferrer"
                        >
                          {feed.siteUrl
                            .replace(/^https?:\/\//, "")
                            .replace(/\/$/, "")}
                        </a>
                      ) : null}
                    </div>
                  </div>

                  <div class="mt-4">
                    {feed.items.length ? (
                      <div
                        class="relative flex gap-3 pb-1"
                        style="overflow-x: auto; overflow-y: visible;"
                      >
                        {feed.items.map((item) => (
                          <div
                            class="group relative z-0 min-w-[280px] max-w-md flex-1 rounded-xl border border-slate-100 bg-slate-50/70 p-3 pb-10 transition hover:border-(--accent) hover:bg-white hover:z-10 after:clear-both after:block after:content-['']"
                          >
                            {item.image ? (
                              <div class="float-right ml-3 mb-2 h-24 w-28 overflow-hidden rounded-lg border border-slate-100 bg-slate-100">
                                <img
                                  src={item.image}
                                  alt={item.title}
                                  loading="lazy"
                                  decoding="async"
                                  class="h-full w-full object-cover transition duration-300 group-hover:scale-[1.02]"
                                />
                              </div>
                            ) : null}
                            <div class="flex flex-wrap items-center gap-2 text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">
                              <span class="text-(--accent)">
                                {formatDate(item.publishedAt)}
                              </span>
                            </div>
                            <a
                              href={item.link}
                              target="_blank"
                              rel="noreferrer"
                              class="mt-1 block text-base font-semibold text-slate-900 transition hover:text-(--accent)"
                            >
                              {item.title}
                            </a>
                            {item.summary ? (
                              <p class="mt-1 text-sm text-slate-600">
                                {item.summary}
                              </p>
                            ) : null}
                            <div class="absolute bottom-3 right-3 text-sm text-(--accent)">
                              <a
                                href={item.link}
                                target="_blank"
                                rel="noreferrer"
                                class="inline-flex items-center gap-1 font-semibold"
                              >
                                {t("home.communityFeed.readMore")}
                                <span aria-hidden="true">↗</span>
                              </a>
                            </div>
                          </div>
                        ))}
                      </div>
                    ) : (
                      <p class="rounded-xl border border-slate-100 bg-slate-50/70 px-3 py-4 text-sm text-slate-600">
                        {t("home.communityFeed.emptyFeed")}
                      </p>
                    )}
                  </div>
                </article>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <section id="why-join" class="bg-white/95 px-6 py-16 md:px-12">
      <div class="mx-auto max-w-5xl">
        <h2 class="text-3xl font-semibold text-slate-900">
          {t("home.whyJoin.title")}
        </h2>
        <WhyJoin items={benefits} />
      </div>
    </section>

    <section id="who-comes" class="bg-white/95 px-6 py-16 md:px-12">
      <div class="mx-auto flex max-w-5xl flex-col gap-10 lg:flex-row">
        <div class="flex-1">
          <h2 class="text-3xl font-semibold text-slate-900">
            {t("home.whoComes.title")}
          </h2>
          <p class="mt-4 text-slate-600">{t("home.whoComes.intro")}</p>
          <ul
            class="mt-6 list-disc space-y-3 pl-5 text-base leading-relaxed text-slate-600"
          >
            <li>{t("home.whoComes.item1")}</li>
            <li>{t("home.whoComes.item2")}</li>
            <li>{t("home.whoComes.item3")}</li>
            <li>{t("home.whoComes.item4")}</li>
            <li>{t("home.whoComes.item5")}</li>
          </ul>
        </div>
        <div class="flex-1 space-y-4">
          <div
            class="rounded-2xl bg-white/90 p-6 shadow-lg shadow-stone-900/10 ring-1 ring-white/70"
          >
            <h3 class="text-xl font-semibold text-slate-900">
              {t("home.languages.title")}
            </h3>
            <p class="mt-3 text-base leading-relaxed text-slate-600">
              {t("home.languages.description")}
            </p>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer lang={lang} />
</Layout>
