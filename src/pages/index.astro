---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import Calendar from "../components/Calendar.astro";
import UpcomingEventList from "../components/UpcomingEventList.astro";
import LiveEventUpdater from "../components/LiveEventUpdater.astro";
import Footer from "../components/Footer.astro";
import { FaDiscord, FaEnvelope, FaExternalLinkAlt, FaGithub, FaLinkedin, FaMeetup } from "react-icons/fa";
import { FaComments, FaEarthAsia, FaLanguage, FaLayerGroup } from "react-icons/fa6";
import FeedTimestamps from "../components/FeedTimestamps.astro";
import { useTranslations } from "../i18n/utils";
import memberFeeds from "../data/member-feeds.json";
import compositeFeed from "../data/composite-feed.json";
import meetupEventData from "../data/meetup-events.json";
import {
  isMeetupEvent,
  selectNextMeetupEvent,
  selectUpcomingMeetupEvents,
} from "../lib/meetup-events";
import { getMemberMilestone } from "../lib/member-milestone";
import { getSafeWebUrl } from "../lib/safe-url";

const { lang = "en" } = Astro.props;
const t = useTranslations(lang);

const firstMeetupSignals = [
  { icon: FaComments, label: t("home.firstMeetup.signal1") },
  { icon: FaLanguage, label: t("home.firstMeetup.signal2") },
  { icon: FaLayerGroup, label: t("home.firstMeetup.signal3") },
  { icon: FaEarthAsia, label: t("home.firstMeetup.signal4") },
] as const;

const meetupUrl =
  lang === "ja"
    ? "https://www.meetup.com/ja-JP/kyoto-tech-meetup/"
    : "https://www.meetup.com/kyoto-tech-meetup/";
const discordUrl = "https://discord.gg/mXFWEHDKeu";
const linkedinUrl = "https://www.linkedin.com/company/kyoto-tech-meetup/";
const githubUrl = "https://github.com/kyoto-tech";
const contactUrl = "https://forms.gle/NPtc1G1vM9jGBYhp6";
const memberFeedsEditUrl =
  "https://github.com/kyoto-tech/kyoto-tech.github.io/edit/main/src/data/member-feeds.json";

const quickLinks = [
  {
    href: meetupUrl,
    analyticsName: "meetup",
    icon: FaMeetup,
    titleKey: "home.quickLinks.meetup.title",
    descriptionKey: "home.quickLinks.meetup.description",
  },
  {
    href: discordUrl,
    analyticsName: "discord",
    icon: FaDiscord,
    titleKey: "home.quickLinks.discord.title",
    descriptionKey: "home.quickLinks.discord.description",
  },
  {
    href: githubUrl,
    analyticsName: "github",
    icon: FaGithub,
    titleKey: "home.quickLinks.github.title",
    descriptionKey: "home.quickLinks.github.description",
  },
  {
    href: linkedinUrl,
    analyticsName: "linkedin",
    icon: FaLinkedin,
    titleKey: "home.quickLinks.linkedin.title",
    descriptionKey: "home.quickLinks.linkedin.description",
  },
  {
    href: contactUrl,
    analyticsName: "contact",
    icon: FaEnvelope,
    titleKey: "home.quickLinks.contact.title",
    descriptionKey: "home.quickLinks.contact.description",
  },
] as const;

const calendarLegendItems = [
  {
    titleKey: "home.calendar.legend.coffee.title",
    descriptionKey: "home.calendar.legend.coffee.description",
    image: "/images/kyoto-tech-morning-tech-&-coffee.jpg",
    colorClass: "bg-(--accent)",
    imageClass: "object-[center_65%]",
  },
  {
    titleKey: "home.calendar.legend.hackDay.title",
    descriptionKey: "home.calendar.legend.hackDay.description",
    image: "/images/kyoto-tech-meetup-hack-day.jpg",
    colorClass: "bg-teal-700",
    imageClass: "object-center",
  },
  {
    titleKey: "home.calendar.legend.special.title",
    descriptionKey: "home.calendar.legend.special.description",
    image: "/images/kyoto-tech-meetup-hack-day_2.jpg",
    colorClass: "bg-violet-700",
    imageClass: "object-center",
  },
] as const;

type MemberFeed = {
  name: string;
  siteUrl: string;
  feedUrl: string;
};

type CompositeItem = {
  id: string;
  title: string;
  link: string;
  publishedAt: string;
  summary?: string;
  image?: string | null;
  source: MemberFeed;
};

type CompositeFeed = MemberFeed & {
  items: CompositeItem[];
  error?: string;
};

const locale = lang === "ja" ? "ja-JP" : "en-US";
const cachedMeetupEvents = Array.isArray(meetupEventData?.events)
  ? (meetupEventData.events as unknown[]).filter(isMeetupEvent)
  : [];
const buildNow = new Date();
const events = selectUpcomingMeetupEvents(cachedMeetupEvents, {
  now: buildNow,
});
const nextEvent = selectNextMeetupEvent(events, { now: buildNow });
const nextEventUrl = nextEvent?.link ?? meetupUrl;
const memberMilestone = getMemberMilestone(
  (meetupEventData as { memberCount?: unknown }).memberCount,
);
const memberMilestoneLabel = memberMilestone
  ? t("home.quickLinks.memberMilestone").replace(
      "{count}",
      String(memberMilestone),
    )
  : null;

const memberFeedList = (memberFeeds as MemberFeed[]) ?? [];
const compositeFeedEntries = Array.isArray(compositeFeed?.feeds)
  ? (compositeFeed.feeds as CompositeFeed[])
  : [];
const feedsWithItems = memberFeedList.map((feed) => {
  const match =
    compositeFeedEntries.find(
      (entry) =>
        entry.feedUrl === feed.feedUrl ||
        entry.siteUrl === feed.siteUrl ||
        entry.name === feed.name,
    ) ?? null;
  return {
    ...feed,
    siteUrl: getSafeWebUrl(feed.siteUrl),
    items: (match?.items ?? []).flatMap((item) => {
      const link = getSafeWebUrl(item.link);
      if (!link) return [];
      return [{ ...item, link, image: getSafeWebUrl(item.image) }];
    }),
    error: match?.error,
  };
});

const formatDate = (value: string) => {
  const date = new Date(value);
  if (Number.isNaN(date.valueOf())) return null;
  return date.toLocaleDateString(locale, {
    timeZone: "Asia/Tokyo",
    month: "short",
    day: "numeric",
    year: "numeric",
  });
};
---

<Layout events={events}>
  <Header
    hasNextEvent={Boolean(nextEvent)}
    lang={lang}
    nextEventUrl={nextEventUrl}
  />

  <div>
    <Hero
      event={nextEvent}
      fallbackCtaLabel={t("home.hero.fallbackCta")}
      fallbackUrl={meetupUrl}
      imageAlt={t("home.hero.imageAlt")}
      lang={lang}
      memberMilestoneLabel={memberMilestoneLabel}
      now={buildNow}
      primaryCtaLabel={t("home.hero.primaryCta")}
      secondaryCtaLabel={t("home.hero.secondaryCta")}
      title={t("home.header.title")}
      subtitle={t("home.header.subtitle")}
    />
  </div>

  <main id="main-content" class="space-y-0">
    <section
      id="first-meetup"
      class="scroll-mt-24 bg-white px-6 py-14 md:px-12 md:py-20"
    >
      <div
        class="mx-auto grid max-w-5xl overflow-hidden rounded-[2rem] border border-slate-200/80 bg-white shadow-xl shadow-stone-900/8 lg:grid-cols-[0.92fr_1.08fr]"
      >
        <div
          class="order-2 min-h-72 overflow-hidden bg-slate-100 lg:order-1 lg:min-h-full"
        >
          <img
            src="/images/kyoto-tech-community-work-session-2.jpg"
            alt={t("home.firstMeetup.imageAlt")}
            width="1024"
            height="682"
            loading="lazy"
            decoding="async"
            class="h-full w-full object-cover object-center"
          />
        </div>

        <div class="order-1 p-7 sm:p-9 lg:order-2 lg:p-12">
          <h2
            class="text-3xl font-semibold tracking-[-0.025em] text-slate-950 sm:text-4xl"
          >
            {t("home.firstMeetup.title")}
          </h2>

          <ul class="mt-8 grid grid-cols-2 gap-x-6 gap-y-7">
            {
              firstMeetupSignals.map(({ icon: Icon, label }) => (
                <li class="min-w-0">
                  <span class="flex h-11 w-11 items-center justify-center rounded-full bg-orange-50 text-(--accent)">
                    <Icon className="h-5 w-5" aria-hidden="true" />
                  </span>
                  <span class="mt-3 block text-sm font-semibold leading-snug text-slate-900 sm:text-base">
                    {label}
                  </span>
                </li>
              ))
            }
          </ul>

          <p
            class="mt-8 border-t border-slate-200 pt-6 text-base leading-relaxed text-slate-600"
          >
            {t("home.firstMeetup.supporting")}
          </p>

          <a
            href={nextEventUrl}
            data-analytics-event="calendar_event_click"
            data-analytics-link="rsvp"
            data-analytics-location="first_meetup"
            class="mt-8 inline-flex min-h-12 items-center justify-center gap-2 rounded-full bg-slate-950 px-6 py-3 text-sm font-semibold text-white transition hover:bg-slate-800 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-slate-950"
          >
            {nextEvent ? t("home.hero.primaryCta") : t("home.hero.fallbackCta")}
            <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </section>

    <section
      id="community-hub"
      class="scroll-mt-24 bg-white px-6 py-12 md:px-12 md:py-16"
    >
      <div class="mx-auto max-w-5xl">
        <h2 class="text-3xl font-semibold text-slate-900">
          {t("home.quickLinks.title")}
        </h2>
        <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-6">
          {
            quickLinks.map((link, index) => (
              <a
                href={link.href}
                target="_blank"
                rel="noreferrer"
                data-analytics-event="community_hub_click"
                data-analytics-link={link.analyticsName}
                data-analytics-location="community_hub"
                class:list={[
                  "group flex h-full items-start gap-3 rounded-2xl border border-slate-200/80 bg-white p-4 shadow-lg shadow-stone-900/5 transition hover:-translate-y-0.5 hover:border-(--accent) focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-slate-700 lg:col-span-2",
                  index === 3 ? "lg:col-start-2" : "",
                ]}
              >
                <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-(--accent)/10 text-(--accent)">
                  <link.icon size={18} aria-hidden="true" />
                </span>
                <span class="flex min-w-0 flex-col">
                  <span class="text-base font-semibold text-slate-900 group-hover:text-(--accent)">
                    {t(link.titleKey)}
                  </span>
                  <span class="mt-1 text-sm text-slate-600">
                    {t(link.descriptionKey)}
                  </span>
                </span>
                <FaExternalLinkAlt
                  className="ml-auto self-center shrink-0 text-xs text-slate-400 transition group-hover:text-(--accent)"
                  aria-hidden="true"
                />
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <section id="calendar" class="scroll-mt-24 bg-white px-6 py-16 md:px-12">
      <div class="mx-auto max-w-5xl">
        <h2 class="text-3xl font-semibold text-slate-900">
          {t("home.calendar.title")}
        </h2>

        <FeedTimestamps
          generatedAt={meetupEventData?.generatedAt}
          intervalHours={3}
          lang={lang}
          updatedLabel={t("home.communityFeed.updated")}
          nextLabel={t("home.communityFeed.nextUpdate")}
        />

        <UpcomingEventList
          events={events}
          lang={lang}
          meetupUrl={meetupUrl}
          now={buildNow}
        />

        <div class="hidden md:block">
          <Calendar events={events} lang={lang} now={buildNow} />
        </div>

        <div class="mt-5 hidden gap-4 text-sm text-slate-700 md:grid md:grid-cols-3">
          {
            calendarLegendItems.map((item) => (
              <article class="overflow-hidden rounded-xl border border-slate-200 bg-white">
                <div class="h-32 overflow-hidden bg-slate-100">
                  <img
                    src={item.image}
                    alt=""
                    loading="lazy"
                    decoding="async"
                    class={`h-full w-full object-cover ${item.imageClass}`}
                  />
                </div>
                <div class="p-4">
                  <div class="flex items-center gap-2">
                    <span
                      class={`h-3 w-3 shrink-0 rounded-full ${item.colorClass}`}
                      aria-hidden="true"
                    />
                    <h3 class="font-semibold text-slate-900">
                      {t(item.titleKey)}
                    </h3>
                  </div>
                  <p class="mt-2">{t(item.descriptionKey)}</p>
                </div>
              </article>
            ))
          }
        </div>

      </div>
    </section>

    <section id="community-feed" class="bg-white px-6 py-16 md:px-12">
      <div class="mx-auto max-w-5xl space-y-8">
        <div
          class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between"
        >
          <div>
            <h2 class="text-3xl font-semibold text-slate-900">
              {t("home.communityFeed.title")}
            </h2>
            <p class="mt-3 text-slate-600">
              {t("home.communityFeed.description")}
            </p>
            {
              compositeFeed?.generatedAt ? (
                <FeedTimestamps
                  generatedAt={compositeFeed.generatedAt}
                  intervalHours={3}
                  lang={lang}
                  updatedLabel={t("home.communityFeed.updated")}
                  nextLabel={t("home.communityFeed.nextUpdate")}
                />
              ) : null
            }
          </div>
        </div>

        <div class="flex flex-col gap-5">
          <div class="space-y-5">
            {
              feedsWithItems.map((feed) => (
                <article class="flex h-full flex-col overflow-visible rounded-2xl border border-slate-200/70 bg-white/95 p-5 shadow-lg shadow-stone-900/5 ring-1 ring-white/80">
                  <div class="flex flex-wrap items-center gap-3">
                    <h3 class="text-lg font-semibold text-slate-900">
                      {feed.name}
                    </h3>
                    <div class="ml-auto flex items-center gap-2">
                      {feed.error ? (
                        <span class="rounded-full bg-amber-100 px-3 py-1 text-xs font-semibold text-amber-800">
                          {t("home.communityFeed.fetchError")}
                        </span>
                      ) : null}
                      {feed.siteUrl ? (
                        <a
                          class="inline-flex min-h-11 items-center rounded-full border border-(--accent) bg-(--accent)/10 px-3 py-1 text-xs font-semibold text-(--accent) focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-slate-700"
                          href={feed.siteUrl}
                          target="_blank"
                          rel="noreferrer"
                        >
                          {feed.siteUrl
                            .replace(/^https?:\/\//, "")
                            .replace(/\/$/, "")}
                        </a>
                      ) : null}
                    </div>
                  </div>

                  <div class="mt-4">
                    {feed.items.length ? (
                      <div
                        class="relative flex gap-3 overflow-x-auto overflow-y-visible pb-1"
                      >
                        {feed.items.map((item) => (
                          <div class="group relative z-0 min-w-[280px] max-w-md flex-1 rounded-xl border border-slate-100 bg-slate-50/70 p-3 pb-10 transition hover:border-(--accent) hover:bg-white hover:z-10 after:clear-both after:block after:content-['']">
                            {item.image ? (
                              <div class="float-right ml-3 mb-2 h-24 w-28 overflow-hidden rounded-lg border border-slate-100 bg-slate-100">
                                <img
                                  src={item.image}
                                  alt=""
                                  loading="lazy"
                                  decoding="async"
                                  class="h-full w-full object-cover transition duration-300 group-hover:scale-[1.02]"
                                />
                              </div>
                            ) : null}
                            <div class="flex flex-wrap items-center gap-2 text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">
                              <span class="text-(--accent)">
                                {formatDate(item.publishedAt)}
                              </span>
                            </div>
                            <a
                              href={item.link}
                              target="_blank"
                              rel="noreferrer"
                              class="mt-1 block rounded-sm text-base font-semibold text-slate-900 transition hover:text-(--accent) focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-slate-700"
                            >
                              {item.title}
                            </a>
                            {item.summary ? (
                              <p class="mt-1 line-clamp-3 text-sm text-slate-600">
                                {item.summary}
                              </p>
                            ) : null}
                            <div class="absolute bottom-3 right-3 text-sm text-(--accent)">
                              <a
                                href={item.link}
                                target="_blank"
                                rel="noreferrer"
                                class="inline-flex min-h-11 items-center gap-1 rounded-sm font-semibold focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-slate-700"
                              >
                                {t("home.communityFeed.readMore")}
                                <span aria-hidden="true">↗</span>
                              </a>
                            </div>
                          </div>
                        ))}
                      </div>
                    ) : (
                      <p class="rounded-xl border border-slate-100 bg-slate-50/70 px-3 py-4 text-sm text-slate-600">
                        {t("home.communityFeed.emptyFeed")}
                      </p>
                    )}
                  </div>
                </article>
              ))
            }
          </div>
        </div>

        <aside
          id="submit-feed"
          class="flex flex-col gap-5 rounded-2xl bg-slate-950 p-6 text-white shadow-xl shadow-stone-900/10 sm:flex-row sm:items-center sm:justify-between"
          aria-labelledby="member-feed-contribution-title"
        >
          <h3
            id="member-feed-contribution-title"
            class="text-2xl font-semibold"
          >
            {t("home.communityFeed.contribute.title")}
          </h3>
          <a
            href={memberFeedsEditUrl}
            target="_blank"
            rel="noreferrer"
            data-analytics-event="feed_submission_click"
            data-analytics-link="github_edit"
            data-analytics-location="community_feed"
            class="inline-flex min-h-12 shrink-0 items-center justify-center gap-2 rounded-full bg-white px-6 py-3 text-sm font-semibold text-slate-950 transition hover:bg-slate-100 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-white"
          >
            <FaGithub className="h-5 w-5" aria-hidden="true" />
            {t("home.communityFeed.contribute.cta")}
            <FaExternalLinkAlt className="h-3 w-3" aria-hidden="true" />
          </a>
        </aside>
      </div>
    </section>
  </main>

  <LiveEventUpdater />
  <Footer lang={lang} />
</Layout>
