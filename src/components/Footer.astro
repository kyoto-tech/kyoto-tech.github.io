---
import {
	FaDiscord,
	FaEnvelope,
	FaGithub,
	FaLinkedin,
	FaMeetup,
} from "react-icons/fa";
import { useTranslations } from "../i18n/utils";

type Props = {
	lang?: "en" | "ja";
};

const { lang = "en" } = Astro.props as Props;
const t = useTranslations(lang);

const meetupUrl =
	lang === "ja"
		? "https://www.meetup.com/ja-JP/kyoto-tech-meetup/"
		: "https://www.meetup.com/kyoto-tech-meetup/";
const contactUrl = "https://forms.gle/NPtc1G1vM9jGBYhp6";
const linkedinUrl = "https://www.linkedin.com/company/kyoto-tech-meetup/";
---

<footer class="bg-stone-950 px-6 py-12 text-slate-100 md:px-12">
	<div class="mx-auto flex max-w-5xl flex-col gap-6 md:flex-row md:items-center md:justify-between">
		<p class="text-sm text-slate-300">
			© 2025–{new Date().getFullYear()} {t("home.footer.copyright")}
		</p>
		<nav aria-label={t("home.footer.socialNavLabel")}>
			<ul class="flex flex-wrap gap-x-4 gap-y-1 text-sm font-medium text-slate-200">
				<li>
					<a
						class="flex min-h-11 items-center gap-2 rounded-sm transition hover:text-white"
						href="https://github.com/kyoto-tech"
						target="_blank"
						rel="noreferrer"
						data-analytics-event="community_hub_click"
						data-analytics-link="github"
						data-analytics-location="footer"
					>
						<FaGithub className="text-lg" aria-hidden="true" /> {t("home.footer.github")}
					</a>
				</li>
				<li>
					<a
						class="flex min-h-11 items-center gap-2 rounded-sm transition hover:text-white"
						href="https://discord.gg/mXFWEHDKeu"
						target="_blank"
						rel="noreferrer"
						data-analytics-event="discord_click"
						data-analytics-link="discord"
						data-analytics-location="footer"
					>
						<FaDiscord className="text-lg" aria-hidden="true" /> {t("home.footer.discord")}
					</a>
				</li>
				<li>
					<a
						class="flex min-h-11 items-center gap-2 rounded-sm transition hover:text-white"
						href={linkedinUrl}
						target="_blank"
						rel="noreferrer"
						data-analytics-event="community_hub_click"
						data-analytics-link="linkedin"
						data-analytics-location="footer"
					>
						<FaLinkedin className="text-lg" aria-hidden="true" /> {t("home.footer.linkedin")}
					</a>
				</li>
				<li>
					<a
						class="flex min-h-11 items-center gap-2 rounded-sm transition hover:text-white"
						href={meetupUrl}
						target="_blank"
						rel="noreferrer"
						data-analytics-event="community_hub_click"
						data-analytics-link="meetup"
						data-analytics-location="footer"
					>
						<FaMeetup className="text-lg" aria-hidden="true" /> {t("home.footer.meetup")}
					</a>
				</li>
				<li>
					<a
						class="flex min-h-11 items-center gap-2 rounded-sm transition hover:text-white"
						href={contactUrl}
						target="_blank"
						rel="noreferrer"
						data-analytics-event="community_hub_click"
						data-analytics-link="contact"
						data-analytics-location="footer"
					>
						<FaEnvelope className="text-lg" aria-hidden="true" />
						{t("home.footer.contact")}
					</a>
				</li>
			</ul>
		</nav>
	</div>
</footer>
