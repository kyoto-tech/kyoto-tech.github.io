---
import { FaExternalLinkAlt, FaGithub } from "react-icons/fa";
import FeedTimestamps from "./FeedTimestamps.astro";
import { useTranslations } from "../i18n/utils";

type FeedItem = {
  id: string;
  title: string;
  link: string;
  publishedAt: string;
  summary?: string;
  image?: string | null;
  source?: { imageStrategy?: string };
};

type Feed = {
  name: string;
  siteUrl: string | null;
  items: FeedItem[];
  error?: string;
};

type Props = {
  feeds: Feed[];
  generatedAt?: string;
  lang: "en" | "ja";
  memberFeedsEditUrl: string;
};

const { feeds, generatedAt, lang, memberFeedsEditUrl } = Astro.props as Props;
const t = useTranslations(lang);
const locale = lang === "ja" ? "ja-JP" : "en-US";

const formatDate = (value: string) => {
  const date = new Date(value);
  if (Number.isNaN(date.valueOf())) return null;
  return date.toLocaleDateString(locale, {
    timeZone: "Asia/Tokyo",
    month: "short",
    day: "numeric",
    year: "numeric",
  });
};
---

<section id="community-feed" class="bg-white px-6 py-16 md:px-12">
  <div class="mx-auto max-w-5xl space-y-8">
    <div>
      <h2 class="text-3xl font-semibold text-slate-900">
        {t("home.communityFeed.title")}
      </h2>
      <p class="mt-3 text-slate-600">
        {t("home.communityFeed.description")}
      </p>
      {
        generatedAt ? (
          <FeedTimestamps
            generatedAt={generatedAt}
            intervalHours={3}
            lang={lang}
            updatedLabel={t("home.communityFeed.updated")}
            nextLabel={t("home.communityFeed.nextUpdate")}
          />
        ) : null
      }
    </div>

    <div class="space-y-5">
      {
        feeds.map((feed) => (
          <article class="flex h-full flex-col overflow-visible rounded-2xl border border-slate-200/70 bg-white/95 p-5 shadow-lg shadow-stone-900/5 ring-1 ring-white/80">
            <div class="flex flex-wrap items-center gap-3">
              <h3 class="text-lg font-semibold text-slate-900">{feed.name}</h3>
              <div class="ml-auto flex items-center gap-2">
                {feed.error ? (
                  <span class="rounded-full bg-amber-100 px-3 py-1 text-xs font-semibold text-amber-800">
                    {t("home.communityFeed.fetchError")}
                  </span>
                ) : null}
                {feed.siteUrl ? (
                  <a
                    class="inline-flex min-h-11 items-center rounded-full border border-(--accent) bg-(--accent)/10 px-3 py-1 text-xs font-semibold text-(--accent) focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-slate-700"
                    href={feed.siteUrl}
                    target="_blank"
                    rel="noreferrer"
                  >
                    {feed.siteUrl.replace(/^https?:\/\//, "").replace(/\/$/, "")}
                  </a>
                ) : null}
              </div>
            </div>

            <div class="mt-4">
              {feed.items.length ? (
                <div class="relative flex gap-3 overflow-x-auto overflow-y-visible pb-1">
                  {feed.items.map((item) => {
                    const featuredImage = item.source?.imageStrategy === "linked-page-featured";
                    return (
                      <div class="group relative z-0 min-w-[280px] max-w-md flex-1 rounded-xl border border-slate-100 bg-slate-50/70 p-3 pb-10 transition hover:z-10 hover:border-(--accent) hover:bg-white after:clear-both after:block after:content-['']">
                        {item.image ? (
                          <div class:list={[
                            "float-right mb-2 ml-3 h-24 w-28 overflow-hidden rounded-lg border border-slate-100",
                            featuredImage ? "bg-slate-950" : "bg-slate-100",
                          ]}>
                            <img
                              src={item.image}
                              alt=""
                              loading="lazy"
                              decoding="async"
                              class:list={[
                                "h-full w-full transition duration-300",
                                featuredImage ? "object-contain" : "object-cover group-hover:scale-[1.02]",
                              ]}
                            />
                          </div>
                        ) : null}
                        <div class="flex flex-wrap items-center gap-2 text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">
                          <span class="text-(--accent)">{formatDate(item.publishedAt)}</span>
                        </div>
                        <a
                          href={item.link}
                          target="_blank"
                          rel="noreferrer"
                          class="mt-1 block rounded-sm text-base font-semibold text-slate-900 transition hover:text-(--accent) focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-slate-700"
                        >
                          {item.title}
                        </a>
                        {item.summary ? (
                          <p class="mt-1 line-clamp-3 text-sm text-slate-600">{item.summary}</p>
                        ) : null}
                        <div class="absolute bottom-3 right-3 text-sm text-(--accent)">
                          <a
                            href={item.link}
                            target="_blank"
                            rel="noreferrer"
                            class="inline-flex min-h-11 items-center gap-1 rounded-sm font-semibold focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-slate-700"
                          >
                            {t("home.communityFeed.readMore")}
                            <span aria-hidden="true">↗</span>
                          </a>
                        </div>
                      </div>
                    );
                  })}
                </div>
              ) : (
                <p class="rounded-xl border border-slate-100 bg-slate-50/70 px-3 py-4 text-sm text-slate-600">
                  {t("home.communityFeed.emptyFeed")}
                </p>
              )}
            </div>
          </article>
        ))
      }
    </div>

    <aside
      id="submit-feed"
      class="flex flex-col gap-5 rounded-2xl bg-slate-950 p-6 text-white shadow-xl shadow-stone-900/10 sm:flex-row sm:items-center sm:justify-between"
      aria-labelledby="member-feed-contribution-title"
    >
      <h3 id="member-feed-contribution-title" class="text-2xl font-semibold">
        {t("home.communityFeed.contribute.title")}
      </h3>
      <a
        href={memberFeedsEditUrl}
        target="_blank"
        rel="noreferrer"
        data-analytics-event="feed_submission_click"
        data-analytics-link="github_edit"
        data-analytics-location="community_feed"
        class="inline-flex min-h-12 shrink-0 items-center justify-center gap-2 rounded-full bg-white px-6 py-3 text-sm font-semibold text-slate-950 transition hover:bg-slate-100 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-white"
      >
        <FaGithub className="h-5 w-5" aria-hidden="true" />
        {t("home.communityFeed.contribute.cta")}
        <FaExternalLinkAlt className="h-3 w-3" aria-hidden="true" />
      </a>
    </aside>
  </div>
</section>
