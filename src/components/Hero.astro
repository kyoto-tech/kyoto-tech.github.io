---
import type { MeetupEvent } from "../lib/meetup-events";
import NextEventCard from "./NextEventCard.astro";

type Props = {
  event: MeetupEvent | null;
  fallbackCtaLabel: string;
  fallbackUrl: string;
  imageAlt: string;
  imageSrc: string;
  lang?: "en" | "ja";
  now?: Date;
  primaryCtaLabel: string;
  reassurance: string;
  secondaryCtaLabel: string;
  subtitle: string;
  title: string;
};

const {
  event,
  fallbackCtaLabel,
  fallbackUrl,
  imageAlt,
  imageSrc,
  lang = "en",
  now = new Date(),
  primaryCtaLabel,
  reassurance,
  secondaryCtaLabel,
  subtitle,
  title,
} = Astro.props as Props;
const primaryCtaUrl = event?.link ?? fallbackUrl;
---

<header class="relative isolate min-h-[50rem] overflow-hidden bg-slate-950 shadow-2xl shadow-slate-950/20 sm:mx-4 sm:rounded-[2rem] lg:mx-0 lg:min-h-[40rem]">
  <img
    src={imageSrc}
    alt={imageAlt}
    width="1080"
    height="719"
    loading="eager"
    fetchpriority="high"
    decoding="async"
    class="absolute inset-0 -z-30 h-full w-full object-cover object-center"
  />
  <div class="absolute inset-0 -z-20 bg-slate-950/20 lg:bg-slate-950/5" aria-hidden="true"></div>
  <div class="absolute inset-0 -z-10 bg-gradient-to-r from-slate-950/85 via-slate-950/55 to-slate-950/15 lg:via-slate-950/45 lg:to-transparent" aria-hidden="true"></div>
  <div class="absolute inset-0 -z-10 bg-gradient-to-t from-slate-950/45 via-transparent to-slate-950/10" aria-hidden="true"></div>

  <div class="grid min-h-[50rem] grid-cols-1 content-start items-start gap-y-6 px-6 py-10 sm:px-10 sm:py-12 lg:min-h-[40rem] lg:grid-cols-[minmax(0,1fr)_minmax(22rem,0.76fr)] lg:grid-rows-[auto_auto] lg:content-end lg:gap-x-14 lg:gap-y-7 lg:px-12 lg:py-14">
    <div class="order-1 lg:col-start-1 lg:row-start-1">
      <h1
        class:list={[
          "max-w-2xl whitespace-pre-line break-keep font-semibold leading-[1.04] tracking-[-0.035em] text-white drop-shadow-sm",
          lang === "ja"
            ? "text-4xl sm:text-5xl lg:text-5xl"
            : "text-4xl sm:text-5xl lg:text-6xl",
        ]}
      >
        {title}
      </h1>
      <p class="mt-5 max-w-xl text-lg leading-relaxed text-slate-100 drop-shadow-sm">
        {subtitle}
      </p>
    </div>

    <div class="order-2 lg:col-start-2 lg:row-start-1 lg:row-span-2 lg:self-end">
      <NextEventCard event={event} fallbackUrl={fallbackUrl} lang={lang} now={now} />
    </div>

    <div class="order-3 lg:col-start-1 lg:row-start-2">
      <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
        <a
          href={primaryCtaUrl}
          class="inline-flex min-h-12 items-center justify-center rounded-full bg-white px-6 py-3 text-sm font-semibold text-slate-950 shadow-lg shadow-slate-950/15 transition hover:bg-slate-100 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-white"
        >
          {event ? primaryCtaLabel : fallbackCtaLabel}
        </a>
        <a
          href="#calendar"
          class="inline-flex min-h-12 items-center justify-center rounded-full border border-white/50 bg-slate-950/25 px-6 py-3 text-sm font-semibold text-white backdrop-blur-sm transition hover:border-white/80 hover:bg-slate-950/40 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-white"
        >
          {secondaryCtaLabel}
        </a>
      </div>
      <p class="mt-3 text-sm leading-relaxed text-slate-200 drop-shadow-sm">
        {reassurance}
      </p>
    </div>
  </div>
</header>
