---
import { getMemberById } from "../../utils/community-feed";
import { TAG_LABELS, type TagId } from "../../types/community-feed";
import type { Post } from "../../types/community-feed";
import { useTranslations } from "../../i18n/utils";

type Props = {
  post: Post;
  lang: "en" | "ja";
};

const { post, lang } = Astro.props;
const t = useTranslations(lang);
const member = getMemberById(post.member);
const firstTag = post.tags[0] as TagId;
const tagLabel = TAG_LABELS[firstTag]?.[lang] ?? firstTag;

const FALLBACK_GRADIENTS: Record<string, string> = {
  blog: "linear-gradient(135deg, #f5f0eb, #e8e0d8)",
  video: "linear-gradient(135deg, #2a2a35, #1a1a25)",
  project: "linear-gradient(135deg, #eaf2ed, #d8e8df)",
};
const FALLBACK_EMOJI: Record<string, string> = {
  blog: "\u{1F4DD}",
  video: "\u{1F3AC}",
  project: "\u{1F680}",
};

const hasThumbnail = !!post.thumbnail;
const fallbackGradient = FALLBACK_GRADIENTS[post.type];
const fallbackEmoji = FALLBACK_EMOJI[post.type];
---

<article
  class="cf-card group overflow-hidden rounded-xl border border-[#e8e4df] bg-white shadow-[0_1px_3px_rgba(0,0,0,0.06)] transition-all duration-200 hover:-translate-y-0.5 hover:border-[#d0ccc6] hover:shadow-[0_8px_24px_rgba(0,0,0,0.08)]"
  data-type={post.type}
  data-member={post.member}
  data-tags={post.tags.join(",")}
  data-date={post.date}
>
  <!-- Thumbnail with overlaid title -->
  <a href={post.url} target="_blank" rel="noopener noreferrer" class="block">
    <div
      class="relative h-[200px] overflow-hidden"
      style={!hasThumbnail ? `background: ${fallbackGradient}` : undefined}
    >
      {hasThumbnail ? (
        <img
          src={post.thumbnail}
          alt=""
          class="h-full w-full object-cover transition-transform duration-400 group-hover:scale-[1.03]"
          loading="lazy"
        />
      ) : (
        <div class="flex h-full items-center justify-center text-5xl">
          {fallbackEmoji}
        </div>
      )}
      {/* Dark gradient overlay for text readability */}
      <div class="absolute inset-0" style="background: linear-gradient(transparent 40%, rgba(0,0,0,0.7) 100%);" />
      <div class="absolute bottom-0 left-0 p-4">
        <h3 class="line-clamp-2 text-[15px] font-bold leading-snug text-white">
          {post.title}
        </h3>
        <span class="mt-1 block text-[10px] font-semibold uppercase tracking-wider text-white/80">
          {tagLabel}
        </span>
      </div>
    </div>
  </a>

  <!-- Card body -->
  <div class="p-4">
    {post.description && (
      <p class="line-clamp-2 text-[13px] leading-relaxed text-[#444]">
        {post.description}
      </p>
    )}

    <div class="mt-3 flex items-center justify-between">
      {member && (
        <a
          href={member.website}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 text-[13px] font-medium text-slate-400 transition-colors hover:text-slate-600"
        >
          <span class="flex h-6 w-6 items-center justify-center rounded-full bg-slate-100 text-[10px] text-slate-400">
            {member.name.charAt(0)}
          </span>
          {t("communityFeed.author")}: {member.name}
        </a>
      )}
      <a
        href={post.url}
        target="_blank"
        rel="noopener noreferrer"
        class="text-slate-300 transition-colors hover:text-slate-500"
        aria-label={`Read: ${post.title}`}
      >
        &rarr;
      </a>
    </div>

    {post.type === "project" && (
      <div class="mt-3 space-y-2">
        <div class="flex flex-wrap gap-2">
          <a
            href={post.url}
            target="_blank"
            rel="noopener noreferrer"
            class="text-xs font-medium text-[#c4703c] hover:text-[#a85d30]"
          >
            &#128279; {t("communityFeed.liveDemo")}
          </a>
          {post.repoUrl && (
            <a
              href={post.repoUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="text-xs font-medium text-[#c4703c] hover:text-[#a85d30]"
            >
              &#128230; {t("communityFeed.github")}
            </a>
          )}
        </div>
        {post.techStack && post.techStack.length > 0 && (
          <div class="flex flex-wrap gap-1.5">
            {post.techStack.map((tech: string) => (
              <span class="rounded bg-[#ecf5ef] px-2 py-0.5 font-mono text-[11px] text-[#2d7a4f]">
                {tech}
              </span>
            ))}
          </div>
        )}
      </div>
    )}

    {/* Extra excerpt line for non-project cards */}
    {post.type !== "project" && post.description && (
      <p class="mt-2 line-clamp-1 text-[12px] text-slate-400">
        {post.description}
      </p>
    )}
  </div>
</article>
