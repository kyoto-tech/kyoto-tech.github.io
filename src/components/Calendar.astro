---
import FullCalendarView from "../components/FullCalendarView.jsx";
import type { MeetupEvent } from "../lib/meetup-events";
import {
  getFiveWeekCalendarRange,
  toFullCalendarEvents,
} from "../lib/full-calendar-events";

type Props = {
  events: MeetupEvent[];
  lang?: "en" | "ja";
};

const { events, lang = "en" } = Astro.props as Props;
const calendarEvents = toFullCalendarEvents(events);
const range = getFiveWeekCalendarRange();
---

<section class="pt-6 pb-6">
  <FullCalendarView
    client:load
    events={calendarEvents}
    range={range}
    lang={lang}
  />
</section>
