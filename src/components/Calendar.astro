---
import {
  buildMeetupVenueMapsUrl,
  type MeetupEvent,
} from "../lib/meetup-events";
import { buildFiveWeekCalendar } from "../lib/calendar-grid";
import { isOngoingEvent } from "../lib/event-status";
import { useTranslations } from "../i18n/utils";
import { FaLocationDot, FaUserGroup } from "react-icons/fa6";

type Props = {
  events: MeetupEvent[];
  lang?: "en" | "ja";
  now?: Date;
};

const { events, lang = "en", now = new Date() } = Astro.props as Props;
const t = useTranslations(lang);
const locale = lang === "ja" ? "ja-JP" : "en-US";
const weeks = buildFiveWeekCalendar(events);
const rangeStart = weeks[0]?.[0]?.dateKey;
const weekdayLabels = Array.from({ length: 7 }, (_, index) => {
  const date = new Date(Date.UTC(2026, 0, 5 + index));
  return new Intl.DateTimeFormat(locale, {
    timeZone: "UTC",
    weekday: "short",
  }).format(date);
});

const formatFullDate = (dateKey: string) =>
  new Intl.DateTimeFormat(locale, {
    day: "numeric",
    month: "long",
    timeZone: "UTC",
    year: "numeric",
  }).format(new Date(`${dateKey}T00:00:00.000Z`));

const formatDayNumber = (dateKey: string, dayNumber: number) => {
  if (dateKey !== rangeStart && dayNumber !== 1) return String(dayNumber);
  return new Intl.DateTimeFormat(locale, {
    day: "numeric",
    month: "short",
    timeZone: "UTC",
  }).format(new Date(`${dateKey}T00:00:00.000Z`));
};

const eventColorClass = (event: MeetupEvent) => {
  if (event.eventType === "hack-day") return "bg-teal-700 hover:bg-teal-800";
  if (event.eventType === "special") return "bg-violet-700 hover:bg-violet-800";
  return "bg-(--accent) hover:bg-(--accent-dark)";
};
---

<section class="pb-6 pt-6">
  <div class="overflow-x-auto rounded-xl border border-slate-200 bg-white pb-1">
    <table class="w-full min-w-[54rem] table-fixed border-collapse" aria-label={t("home.calendar.title")}>
      <thead>
        <tr>
          {
            weekdayLabels.map((label) => (
              <th
                scope="col"
                class="border-b border-r border-slate-200 bg-slate-50 px-2 py-2 text-center text-xs font-semibold uppercase tracking-[0.12em] text-slate-500 last:border-r-0"
              >
                {label}
              </th>
            ))
          }
        </tr>
      </thead>
      <tbody>
        {
          weeks.map((week) => (
            <tr>
              {week.map((day) => (
                <td
                  class:list={[
                    "h-32 border-b border-r border-slate-200 p-2 align-top last:border-r-0",
                    day.isToday ? "bg-(--accent)/8" : "bg-white",
                  ]}
                >
                  <time
                    datetime={day.dateKey}
                    aria-label={formatFullDate(day.dateKey)}
                    class="block text-right text-sm font-semibold text-slate-700"
                  >
                    {formatDayNumber(day.dateKey, day.dayNumber)}
                  </time>
                  <div class="mt-2 grid gap-1.5">
                    {
                      day.events.map((event) => {
                        const mapsUrl = buildMeetupVenueMapsUrl(event.venue);
                        const venueLabel =
                          event.venue?.name ?? event.venue?.address ?? "";
                        const ongoing = isOngoingEvent(event, now);

                        return (
                          <article
                            class:list={[
                              "rounded-lg px-2 py-2 text-xs text-white shadow-sm transition",
                              eventColorClass(event),
                            ]}
                            data-event-live
                            data-event-start={event.start}
                            data-event-end={event.endTime ?? undefined}
                            data-live-state={ongoing ? "ongoing" : "upcoming"}
                            data-live-emphasis="calendar"
                          >
                            <span
                              class="mb-1.5 inline-flex items-center gap-1 rounded-full bg-white/95 px-1.5 py-0.5 text-[0.625rem] font-bold uppercase tracking-wide text-emerald-700"
                              data-live-only
                              hidden={!ongoing}
                            >
                              <span
                                class="h-1.5 w-1.5 rounded-full bg-emerald-500"
                                aria-hidden="true"
                              />
                              {t("home.eventCard.liveNow")}
                            </span>
                            <a
                              href={event.link}
                              data-analytics-event="calendar_event_click"
                              data-analytics-link={event.eventType}
                              data-analytics-location="desktop_calendar"
                              class="block font-semibold leading-snug underline-offset-2 hover:underline focus-visible:rounded-sm focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white"
                            >
                              {event.title}
                            </a>
                            <div class="mt-2 grid gap-1 text-[0.6875rem] font-medium text-white/90">
                              <span
                                class="inline-flex items-center gap-1.5"
                              >
                                <span class="sr-only">
                                  {t("home.calendar.rsvpCount").replace(
                                    "{count}",
                                    String(event.goingCount),
                                  )}
                                </span>
                                <FaUserGroup
                                  className="h-3 w-3 shrink-0"
                                  aria-hidden="true"
                                />
                                <span aria-hidden="true">
                                  {event.goingCount}
                                </span>
                              </span>
                              {mapsUrl && (
                                <a
                                  href={mapsUrl}
                                  target="_blank"
                                  rel="noreferrer"
                                  data-analytics-event="calendar_event_click"
                                  data-analytics-link="maps"
                                  data-analytics-location="desktop_calendar"
                                  class="inline-flex min-h-11 items-center gap-1.5 underline decoration-white/50 underline-offset-2 transition hover:text-white hover:decoration-white focus-visible:rounded-sm focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white"
                                >
                                  <FaLocationDot
                                    className="h-3 w-3 shrink-0"
                                    aria-hidden="true"
                                  />
                                  <span>{t("home.calendar.openInMaps")}</span>
                                  <span class="sr-only">: {venueLabel}</span>
                                </a>
                              )}
                            </div>
                          </article>
                        );
                      })
                    }
                  </div>
                </td>
              ))}
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>
</section>
